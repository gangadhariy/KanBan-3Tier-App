pipeline {
    agent {
        label 'agent'
    }

    // tools {
    //     sonarScanner 'sonar-sc-1'
    // }

    environment {
        // Sonarqube url
        SONAR_URL = "http://98.81.245.134:9000/"
        // Docker Envs
        DOCKER_IMAGE = "gangadhariy/kanban-frontend"

        // Nexus placeholders
        NEXUS_URL  = "http://98.81.245.134:8081"
        REPO_NAME  = "raw-hosted"
        DEST_PATH  = "trivy-reports/frontend-${BUILD_ID}.html"
    }

    stages {

        stage('SonarQube Scan') {
            steps {
                def scannerHome = tool 'sonar-sc-1'
                withCredentials([
                    string(credentialsId: 'Sonar_Token', variable: 'SONAR_TOKEN'),
                ]) {
                    sh '''
                        cd frontend
                        sonar-scanner \
                          -Dsonar.projectKey=demo-project \
                          -Dsonar.sources=. \
                          -Dsonar.host.url=${SONAR_URL} \
                          -Dsonar.token=${SONAR_TOKEN}
                    '''
                }
            }
        }

        stage('Docker Build') {
            steps {
                sh '''
                    cd frontend
                    docker build -t ${DOCKER_IMAGE}:${BUILD_ID} .
                '''
            }
        }

        stage('Scan Docker Image') {
            steps {
                sh '''
                    trivy image \
                      --severity HIGH,CRITICAL \
                      --format json \
                      -o trivy-report.json \
                      ${DOCKER_IMAGE}:${BUILD_ID}
                '''
            }
        }

        stage('Generate Professional HTML Report') {
            steps {
                sh '''
                    python3 convert-report-html.py
                '''
            }
        }

        stage('Upload Report to Nexus') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'Nexus-creds',
                        usernameVariable: 'NEXUS_USER',
                        passwordVariable: 'NEXUS_PASS'
                    )
                ]) {
                    sh '''
                        curl -v \
                          -u ${NEXUS_USER}:${NEXUS_PASS} \
                          --upload-file trivy-report.html \
                          ${NEXUS_URL}/repository/${REPO_NAME}/${DEST_PATH}
                    '''
                }
            }
        }

        stage('Docker Push') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'Docker-Creds',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASSWORD'
                    )
                ]) {
                    sh '''
                        echo ${DOCKER_PASSWORD} | docker login -u ${DOCKER_USER} --password-stdin
                        docker push ${DOCKER_IMAGE}:${BUILD_ID}
                    '''
                }
            }
        }

        stage('Edit the image version in Frontend Argo Manifest Repo') {
            steps {
                withCredentials([
                    string(credentialsId: 'Github_token', variable: 'GITHUB_TOKEN')
                ]) {
                    sh '''
                        git clone https://github.com/gangadhariy/Argo-Rollout-Repo.git

                        cd Argo-Rollout-Repo/Applications/Kanban-api-BG/frontend

                        git config user.name "github-actions"
                        git config user.email "github-actions@github.com"

                        sed -i "s|image: .*|image: ${DOCKER_IMAGE}:${BUILD_ID}|" rollout.yaml

                        git add .

                        git diff --cached --quiet || git commit -m "Update frontend image to ${BUILD_ID}"

                        git push https://${GITHUB_TOKEN}@github.com/gangadhariy/Argo-Rollout-Repo.git HEAD:main
                    '''
                }
            }
        }
    }

    post {
        success {
            cleanWs()
        }

        failure {
            echo "Pipeline failed."
            cleanWs()
        }
    }
}